{
    "$schema": "https://www.schemastore.org/prettierrc.json",
    "arrowParens": "always",
    "useTabs": false,
    "singleQuote": false,
    "trailingComma": "es5",
    "tabWidth": 4,
    "printWidth": 120,
    "singleAttributePerLine": true,
    "plugins": ["prettier-plugin-svelte", "prettier-plugin-tailwindcss"],
    "overrides": [
        {
            "files": "*.svelte",
            "options": {
                "parser": "svelte"
            }
        }
    ],
    "tailwindStylesheet": "./src/routes/layout.css"
}
